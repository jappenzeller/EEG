
!data/**/.gitkeep

# Python
*.py[cod]
*$py.class
*.egg
*.egg-info/
__pycache__/
.eggs/
build/
dist/
.venv/
venv/
env/

# Data files (keep structure, not data)
data/processed/**/*
data/raw/**/*.bdf
data/raw/**/*.npy
data/raw/**/*.npz
data/raw/**/*.txt
data/raw/**/*.h5
data/results/**/*

# AWS credentials (never commit)
.aws/
.aws/credentials

# Session configs with personal info
configs/local_*.yaml

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# Linting / testing / coverage
.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/

# OpenBCI GUI (large Java binaries)
OpenBCI/

# Executables and archives
*.exe
*.dll
*.so
*.dylib
*.zip
*.tar.gz
*.tar
*.gz

# Environment
.env
